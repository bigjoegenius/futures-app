# Futures app environment variables
# Copy this file to `.env` and fill in values. Never commit .env.

# --- AI ---
# Used by market_analyzer.py and autopilot.py for Claude reports + decisions
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional cheaper model for 10-min insights (stubbed if missing)
MINIMAX_API_KEY=

# --- Web controller auth ---
# If missing, web_controller.py generates random tokens and prints them on start.
# Paste the generated ones here so they stick.
WEB_CONTROLLER_TOKEN=
WEB_VIEWER_TOKEN=

# --- Email alerts (run_autopilot.py) ---
# Uses Gmail SMTP with an App Password (Google Account -> Security -> App Passwords)
GMAIL_USER=yourname@gmail.com
GMAIL_APP_PASSWORD=16charapppassword
REPORT_EMAIL_TO=yourname@gmail.com

# --- News cache (optional) ---
# Override TTL seconds for news_provider.py (default 3600 = 1 hour)
NEWS_DIGEST_TTL=3600
